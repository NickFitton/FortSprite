const title = 'Fort Sprite - Fortnite Sprite Checker';
const description = 'Track every current and unreleased Fortnite Sprite variant you have extracted, mastered, or still need to find. Your checklist saves privately in your browser.';
const canonical = 'https://fortsprite.com/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#121826" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Fort Sprite" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebApplication',
      name: 'Fort Sprite',
      url: canonical,
      applicationCategory: 'GameApplication',
      operatingSystem: 'Any',
      description
    })} />
  </head>
  <body>
    <main class="shell">
      <section class="hero" aria-labelledby="page-title">
        <div>
          <p class="eyebrow">Fortnite Sprite Checklist</p>
          <h1 id="page-title">Fort Sprite</h1>
          <p class="intro">
            Mark each sprite as not found, extracted, or mastered. Progress is saved on this device.
          </p>
        </div>
        <div class="summary" aria-label="Sprite progress">
          <div>
            <span id="mastered-count">0</span>
            <small>Mastered</small>
          </div>
          <div>
            <span id="extracted-count">0</span>
            <small>Extracted</small>
          </div>
          <div>
            <span id="missing-count">{sprites.length}</span>
            <small>Not found</small>
          </div>
        </div>
      </section>

      <section class="toolbar" aria-label="Checklist controls">
        <div class="control-stack">
          <div class="filter-group" role="tablist" aria-label="Filter sprites by status">
            <button class="filter is-active" type="button" data-status-filter="all" aria-pressed="true">All</button>
            <button class="filter" type="button" data-status-filter="not-found" aria-pressed="false">Not found</button>
            <button class="filter" type="button" data-status-filter="extracted" aria-pressed="false">Extracted</button>
            <button class="filter" type="button" data-status-filter="mastered" aria-pressed="false">Mastered</button>
          </div>
          <div class="filter-group" role="tablist" aria-label="Filter sprites by variant">
            <button class="filter is-active" type="button" data-variant-filter="all" aria-pressed="true">All variants</button>
            <button class="filter" type="button" data-variant-filter="Base" aria-pressed="false">Base</button>
            <button class="filter" type="button" data-variant-filter="Gold" aria-pressed="false">Gold</button>
            <button class="filter" type="button" data-variant-filter="Gummy" aria-pressed="false">Gummy</button>
            <button class="filter" type="button" data-variant-filter="Galaxy" aria-pressed="false">Galaxy</button>
            <button class="filter" type="button" data-variant-filter="Gem" aria-pressed="false">Gem</button>
            <button class="filter" type="button" data-variant-filter="Holofoil" aria-pressed="false">Holofoil</button>
            <button class="filter" type="button" data-variant-filter="Cube" aria-pressed="false">Cube</button>
            <button class="filter" type="button" data-variant-filter="Quack" aria-pressed="false">Quack</button>
          </div>
          <div class="filter-group" role="tablist" aria-label="Filter sprites by availability">
            <button class="filter is-active" type="button" data-release-filter="all" aria-pressed="true">All availability</button>
            <button class="filter" type="button" data-release-filter="released" aria-pressed="false">Released</button>
            <button class="filter" type="button" data-release-filter="unreleased" aria-pressed="false">Unreleased</button>
          </div>
        </div>
        <button class="reset" type="button" id="reset-progress">Reset</button>
      </section>

      <section class="matrix-wrap" aria-label="Sprite checklist">
        <div class="sprite-matrix">
          <div class="matrix-header sprite-type-heading">Sprite</div>
          {variants.map((variant) => (
            <div class="matrix-header" data-variant-column={variant}>{variant === 'Base' ? 'Regular' : variant}</div>
          ))}

          {spriteRows.map((row) => (
            <>
              <article class="sprite-type" data-sprite-row>
                <p class="element">{row.rarity}</p>
                <h2>{row.name}</h2>
                <p>{row.ability}</p>
              </article>
              {row.cells.map((sprite, index) => (
                sprite ? (
                  <div
                    class="sprite-cell"
                    data-sprite-card
                    data-id={sprite.id}
                    data-variant={sprite.variant}
                    data-released={String(sprite.released)}
                    data-exact-image={String(sprite.hasExactImage)}
                    data-status="not-found"
                  >
                    <div class="cell-art">
                      <img src={sprite.image} alt={sprite.name} loading="lazy" decoding="async" />
                    </div>
                    <div class="cell-meta">
                    </div>
                    <button class="status-button" type="button" data-status-button aria-label={`${sprite.name} status`}>
                      None
                    </button>
                  </div>
                ) : (
                  <div class="sprite-cell empty" data-empty-cell data-variant={variants[index]} aria-label={`No ${variants[index]} variant for ${row.name}`}>-</div>
                )
              ))}
            </>
          ))}
        </div>
      </section>
    </main>

    <script>
      const storageKey = 'fortsprite:v1';
      const cards = Array.from(document.querySelectorAll('[data-sprite-card]'));
      const statusFilters = Array.from(document.querySelectorAll('[data-status-filter]'));
      const variantFilters = Array.from(document.querySelectorAll('[data-variant-filter]'));
      const releaseFilters = Array.from(document.querySelectorAll('[data-release-filter]'));
      const counts = {
        mastered: document.querySelector('#mastered-count'),
        extracted: document.querySelector('#extracted-count'),
        missing: document.querySelector('#missing-count')
      };

      let selectedStatusFilter = 'all';
      let selectedVariantFilter = 'all';
      let selectedReleaseFilter = 'all';
      let state = {};

      try {
        state = JSON.parse(localStorage.getItem(storageKey) || '{}') || {};
      } catch {
        state = {};
      }

      function persist() {
        localStorage.setItem(storageKey, JSON.stringify(state));
      }

      function applyState() {
        const totals = { mastered: 0, extracted: 0, 'not-found': 0 };

        cards.forEach((card) => {
          const id = card.dataset.id;
          const status = state[id] || 'not-found';
          totals[status] += 1;
          card.dataset.status = status;
          const button = card.querySelector('[data-status-button]');
          if (button) {
            button.textContent = status === 'not-found' ? 'None' : status === 'extracted' ? 'Extracted' : 'Mastered';
            button.setAttribute('aria-label', `${button.getAttribute('aria-label').replace(/ status:.*/, ' status')}: ${button.textContent}`);
          }
          const statusMatches = selectedStatusFilter === 'all' || selectedStatusFilter === status;
          const variantMatches = selectedVariantFilter === 'all' || selectedVariantFilter === card.dataset.variant;
          const releaseMatches =
            selectedReleaseFilter === 'all' ||
            (selectedReleaseFilter === 'released' && card.dataset.released === 'true') ||
            (selectedReleaseFilter === 'unreleased' && card.dataset.released === 'false');
          card.hidden = !statusMatches || !variantMatches || !releaseMatches;
        });

        document.querySelectorAll('[data-variant-column], [data-empty-cell]').forEach((item) => {
          item.hidden = selectedVariantFilter !== 'all' && selectedVariantFilter !== item.dataset.variantColumn && selectedVariantFilter !== item.dataset.variant;
        });

        document.querySelectorAll('[data-sprite-row]').forEach((row) => {
          const rowCells = [];
          let sibling = row.nextElementSibling;
          while (sibling && !sibling.matches('[data-sprite-row]')) {
            if (sibling.matches('[data-sprite-card]')) rowCells.push(sibling);
            sibling = sibling.nextElementSibling;
          }
          row.hidden = rowCells.every((cell) => cell.hidden);
        });

        counts.mastered.textContent = String(totals.mastered);
        counts.extracted.textContent = String(totals.extracted);
        counts.missing.textContent = String(totals['not-found']);
      }

      cards.forEach((card) => {
        card.addEventListener('click', (event) => {
          const target = event.target;
          if (!(target instanceof HTMLElement) || !target.matches('[data-status-button]')) return;
          const current = state[card.dataset.id] || 'not-found';
          state[card.dataset.id] =
            current === 'not-found' ? 'extracted' : current === 'extracted' ? 'mastered' : 'not-found';
          persist();
          applyState();
        });
      });

      statusFilters.forEach((button) => {
        button.addEventListener('click', () => {
          selectedStatusFilter = button.dataset.statusFilter;
          statusFilters.forEach((filter) => {
            const active = filter === button;
            filter.classList.toggle('is-active', active);
            filter.setAttribute('aria-pressed', String(active));
          });
          applyState();
        });
      });

      variantFilters.forEach((button) => {
        button.addEventListener('click', () => {
          selectedVariantFilter = button.dataset.variantFilter;
          variantFilters.forEach((filter) => {
            const active = filter === button;
            filter.classList.toggle('is-active', active);
            filter.setAttribute('aria-pressed', String(active));
          });
          applyState();
        });
      });

      releaseFilters.forEach((button) => {
        button.addEventListener('click', () => {
          selectedReleaseFilter = button.dataset.releaseFilter;
          releaseFilters.forEach((filter) => {
            const active = filter === button;
            filter.classList.toggle('is-active', active);
            filter.setAttribute('aria-pressed', String(active));
          });
          applyState();
        });
      });

      document.querySelector('#reset-progress').addEventListener('click', () => {
        state = {};
        persist();
        applyState();
      });

      applyState();
    </script>
  </body>
</html>

