---
import { claimableSprites, spriteRows, variants } from '../data/sprites.js';

const title = 'fortsprite - Fortnite Sprite Checker';
const description = 'Track every current and unreleased Fortnite Sprite variant you have extracted, mastered, or still need to find. Your checklist saves privately in your browser.';
const canonical = 'https://fortsprite.com/';
const previewImage = new URL('/og-image.png', canonical).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/og-image.png" />
    <meta name="theme-color" content="#121826" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="fortsprite" />
    <meta property="og:image" content={previewImage} />
    <meta property="og:image:secure_url" content={previewImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="fortsprite Fortnite Sprite checklist preview" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={previewImage} />
    <meta name="twitter:image:alt" content="fortsprite Fortnite Sprite checklist preview" />

    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebApplication',
      name: 'fortsprite',
      url: canonical,
      image: previewImage,
      applicationCategory: 'GameApplication',
      operatingSystem: 'Any',
      description
    })} />
  </head>
  <body>
    <main class="shell">
      <section class="hero" aria-labelledby="page-title">
        <div>
          <p class="eyebrow">Fortnite Sprite Checklist</p>
          <h1 id="page-title">fortsprite</h1>
          <p class="intro">
            Mark each sprite as not found, extracted, or mastered. Progress is saved on this device.
          </p>
        </div>
        <div class="summary" aria-label="Sprite progress">
          <div>
            <span id="missing-count">{claimableSprites.length}</span>
            <small>Not found</small>
          </div>
          <div>
            <span id="extracted-count">0</span>
            <small>Extracted</small>
          </div>
          <div>
            <span id="mastered-count">0</span>
            <small>Mastered</small>
          </div>
          <button class="share-button" type="button" data-share-image>Share image</button>
        </div>
      </section>

      <section class="matrix-wrap" aria-label="Sprite checklist">
        <div class="sprite-matrix">
          <div class="matrix-header sprite-type-heading">Sprite</div>
          {variants.map((variant) => (
            <div class="matrix-header" data-variant-column={variant}>{variant === 'Base' ? 'Regular' : variant}</div>
          ))}

          {spriteRows.map((row) => (
            <>
              <article class="sprite-type" data-sprite-row>
                <p class="element">{row.rarity}</p>
                <h2><a href={row.path}>{row.name}</a></h2>
                <p>{row.ability}</p>
              </article>
              {row.cells.map((sprite, index) => (
                sprite ? (
                  <div
                    class="sprite-cell"
                    data-sprite-card
                    data-id={sprite.id}
                    data-variant={sprite.variant}
                    data-released={String(sprite.released)}
                    data-exact-image={String(sprite.hasExactImage)}
                    data-status="not-found"
                    role={sprite.released ? 'button' : 'group'}
                    tabindex={sprite.released ? '0' : undefined}
                    aria-label={`${sprite.name} status: None`}
                  >
                    <div class="cell-art">
                      <img src={sprite.image} alt={sprite.name} loading="lazy" decoding="async" />
                    </div>
                    <div class="cell-meta">
                    </div>
                    <span class="status-badge" data-status-badge>
                      {sprite.released ? 'None' : 'Locked'}
                    </span>
                  </div>
                ) : (
                  <div class="sprite-cell empty" data-empty-cell data-variant={variants[index]} aria-label={`No ${variants[index]} variant for ${row.name}`}>-</div>
                )
              ))}
            </>
          ))}
        </div>
      </section>
    </main>

    <script>
      const storageKey = 'fortsprite:v1';
      const cards = Array.from(document.querySelectorAll('[data-sprite-card]'));
      const matrix = document.querySelector('.sprite-matrix');
      const shareButton = document.querySelector('[data-share-image]');
      const counts = {
        mastered: document.querySelector('#mastered-count'),
        extracted: document.querySelector('#extracted-count'),
        missing: document.querySelector('#missing-count')
      };

      let state = {};

      try {
        state = JSON.parse(localStorage.getItem(storageKey) || '{}') || {};
      } catch {
        state = {};
      }

      function persist() {
        localStorage.setItem(storageKey, JSON.stringify(state));
      }

      function applyState() {
        const totals = { mastered: 0, extracted: 0, 'not-found': 0 };

        cards.forEach((card) => {
          const id = card.dataset.id;
          const isReleased = card.dataset.released === 'true';
          const status = state[id] || 'not-found';
          if (isReleased) totals[status] += 1;
          card.dataset.status = status;
          const label = !isReleased ? 'Locked' : status === 'not-found' ? 'None' : status === 'extracted' ? 'Extracted' : 'Mastered';
          const badge = card.querySelector('[data-status-badge]');
          if (badge) {
            badge.textContent = label;
          }
          card.setAttribute('aria-label', `${card.getAttribute('aria-label').replace(/ status:.*/, ' status')}: ${label}`);
        });

        counts.mastered.textContent = String(totals.mastered);
        counts.extracted.textContent = String(totals.extracted);
        counts.missing.textContent = String(totals['not-found']);
      }

      cards.forEach((card) => {
        function cycleStatus() {
          const current = state[card.dataset.id] || 'not-found';
          state[card.dataset.id] =
            current === 'not-found' ? 'extracted' : current === 'extracted' ? 'mastered' : 'not-found';
          persist();
          applyState();
        }

        card.addEventListener('click', () => {
          if (card.dataset.released !== 'true') return;
          cycleStatus();
        });

        card.addEventListener('keydown', (event) => {
          if (card.dataset.released !== 'true') return;
          if (event.key !== 'Enter' && event.key !== ' ') return;
          event.preventDefault();
          cycleStatus();
        });
      });

      function loadImage(src) {
        return new Promise((resolve, reject) => {
          const image = new Image();
          image.decoding = 'async';
          image.addEventListener('load', () => resolve(image), { once: true });
          image.addEventListener('error', () => reject(new Error(`Could not load ${src}`)), { once: true });
          image.src = src;
        });
      }

      function fillVerticalGradient(context, x, y, width, height, top, bottom) {
        const gradient = context.createLinearGradient(0, y, 0, y + height);
        gradient.addColorStop(0, top);
        gradient.addColorStop(1, bottom);
        context.fillStyle = gradient;
        context.fillRect(x, y, width, height);
      }

      async function buildSharePng() {
        if (!matrix) return null;

        await document.fonts?.ready;

        const scale = Math.min(2, window.devicePixelRatio || 1);
        const elements = Array.from(matrix.children);
        const sourceColumnCount = 9;
        const shareColumns = ['Base', 'Gold', 'Gummy', 'Galaxy'];
        const shareColumnIndexes = [0, ...shareColumns.map((variant) =>
          elements.findIndex((element) => element.dataset.variantColumn === variant)
        ).filter((index) => index > 0)];
        const headerHeight = 34;
        const rowHeight = 104;
        const compactNameWidth = 38;
        const columnWidths = shareColumnIndexes.map((_, index) => index === 0 ? compactNameWidth : 76);
        const columnX = columnWidths.reduce((positions, columnWidth, index) => {
          positions.push(index === 0 ? 0 : positions[index - 1] + columnWidths[index - 1]);
          return positions;
        }, []);
        const sourceRows = [];
        for (let rowStart = sourceColumnCount; rowStart < elements.length; rowStart += sourceColumnCount) {
          const rowElements = elements.slice(rowStart, rowStart + sourceColumnCount);
          const hasReleasedCell = shareColumnIndexes.slice(1).some((columnIndex) => (
            rowElements[columnIndex]?.dataset.released === 'true'
          ));
          if (hasReleasedCell) sourceRows.push(rowElements);
        }
        const shareElements = [
          shareColumnIndexes.map((columnIndex) => elements[columnIndex]),
          ...sourceRows.map((rowElements) => shareColumnIndexes.map((columnIndex) => rowElements[columnIndex]))
        ].flat();
        const columnCount = shareColumnIndexes.length;
        const rowCount = sourceRows.length;
        const width = columnWidths.reduce((total, columnWidth) => total + columnWidth, 0);
        const height = headerHeight + rowCount * rowHeight;
        const canvas = document.createElement('canvas');
        canvas.width = Math.round(width * scale);
        canvas.height = Math.round(height * scale);
        const context = canvas.getContext('2d');
        if (!context) return null;

        context.scale(scale, scale);
        fillVerticalGradient(context, 0, 0, width, height, '#070b24', '#162b88');
        context.fillStyle = 'rgba(255, 255, 255, 0.18)';
        context.fillRect(0, 0, width, height);

        const imageEntries = await Promise.all(
          Array.from(matrix.querySelectorAll('.cell-art img')).map(async (node) => {
            try {
              return [node, await loadImage(node.currentSrc || node.src)];
            } catch {
              return [node, null];
            }
          })
        );
        const loadedImages = new Map(imageEntries);

        shareElements.forEach((element, index) => {
          const columnIndex = index % columnCount;
          const rowIndex = Math.floor(index / columnCount);
          const x = columnX[columnIndex];
          const y = rowIndex === 0 ? 0 : headerHeight + (rowIndex - 1) * rowHeight;
          const cellWidth = columnWidths[columnIndex];
          const cellHeight = rowIndex === 0 ? headerHeight : rowHeight;

          if (element.classList.contains('matrix-header')) {
            fillVerticalGradient(context, x, y, cellWidth, cellHeight, '#ffe34d', '#f39c12');
            context.fillStyle = '#171000';
            context.font = '900 14px Inter, ui-sans-serif, system-ui, sans-serif';
            context.textAlign = 'center';
            context.textBaseline = 'middle';
            context.shadowColor = 'rgba(255, 255, 255, 0.38)';
            context.shadowBlur = 0;
            context.shadowOffsetY = 1;
            const headerText = columnIndex === 0 ? '' : element.textContent.trim().toUpperCase();
            context.fillText(headerText, x + cellWidth / 2, y + cellHeight / 2 + 1);
            context.shadowOffsetY = 0;
            return;
          }

          if (element.classList.contains('sprite-type')) {
            const gradient = context.createLinearGradient(x, y, x + cellWidth, y + cellHeight);
            gradient.addColorStop(0, 'rgba(30, 54, 150, 0.98)');
            gradient.addColorStop(1, 'rgba(15, 25, 86, 0.98)');
            context.fillStyle = gradient;
            context.fillRect(x, y, cellWidth, cellHeight);

            context.save();
            context.translate(x + cellWidth / 2, y + cellHeight / 2);
            context.rotate(-Math.PI / 2);
            context.fillStyle = '#ffffff';
            context.font = '900 14px Inter, ui-sans-serif, system-ui, sans-serif';
            context.textAlign = 'center';
            context.textBaseline = 'middle';
            context.shadowColor = 'rgba(0, 0, 0, 0.5)';
            context.shadowBlur = 0;
            context.shadowOffsetY = 2;
            context.fillText(element.querySelector('h2')?.textContent.trim().toUpperCase() || '', 0, 0, cellHeight - 24);
            context.restore();
            return;
          }

          if (element.classList.contains('empty')) {
            context.fillStyle = 'rgba(10, 18, 66, 0.98)';
            context.fillRect(x, y, cellWidth, cellHeight);
            context.fillStyle = 'rgba(174, 184, 199, 0.38)';
            context.font = '900 22px "Burbank Big Condensed", Impact, sans-serif';
            context.textAlign = 'center';
            context.textBaseline = 'middle';
            context.fillText('-', x + cellWidth / 2, y + cellHeight / 2);
            return;
          }

          if (element.classList.contains('sprite-cell')) {
            const status = element.dataset.status;
            if (element.dataset.released === 'false') {
              context.fillStyle = 'rgba(10, 14, 40, 0.92)';
              context.fillRect(x, y, cellWidth, cellHeight);
            } else if (status === 'extracted') {
              fillVerticalGradient(context, x, y, cellWidth, cellHeight, 'rgba(55, 245, 143, 0.22)', 'rgba(10, 18, 66, 0.98)');
            } else if (status === 'mastered') {
              fillVerticalGradient(context, x, y, cellWidth, cellHeight, 'rgba(255, 227, 77, 0.34)', 'rgba(10, 18, 66, 0.98)');
            } else {
              context.fillStyle = 'rgba(10, 18, 66, 0.98)';
              context.fillRect(x, y, cellWidth, cellHeight);
            }

            const imageNode = element.querySelector('.cell-art img');
            const image = loadedImages.get(imageNode);
            if (image) {
              const size = Math.min(64, cellWidth - 16);
              context.save();
              if (element.dataset.released === 'false' || element.dataset.exactImage === 'false') {
                context.globalAlpha = 0.5;
                context.filter = 'brightness(0) saturate(0) invert(0.12)';
              }
              context.shadowColor = 'rgba(0, 0, 0, 0.38)';
              context.shadowBlur = 10;
              context.shadowOffsetY = 7;
              context.drawImage(image, x + (cellWidth - size) / 2, y + 12, size, size);
              context.restore();
            }
          }
        });

        return new Promise((resolve, reject) => {
          canvas.toBlob((png) => {
            if (png) resolve(png);
            else reject(new Error('Could not create PNG image.'));
          }, 'image/png');
        });
      }

      shareButton?.addEventListener('click', async () => {
        if (shareButton.disabled) return;

        const originalLabel = shareButton.textContent;
        shareButton.disabled = true;
        shareButton.textContent = 'Preparing image';

        try {
          const png = await buildSharePng();
          if (!png) throw new Error('Could not create PNG image.');
          const url = URL.createObjectURL(png);
          const link = document.createElement('a');
          link.href = url;
          link.download = `fortsprite-checklist-${new Date().toISOString().slice(0, 10)}.png`;
          document.body.append(link);
          link.click();
          link.remove();
          URL.revokeObjectURL(url);
        } catch (error) {
          console.error(error);
          alert('Could not create the PNG image. Please try again.');
        } finally {
          shareButton.disabled = false;
          shareButton.textContent = originalLabel;
        }
      });

      applyState();
    </script>
  </body>
</html>

<style>
  @font-face {
    font-display: swap;
    font-family: "Burbank Big Condensed";
    font-style: normal;
    font-weight: 900;
    src: url("/fonts/burbank-big-condensed-black.otf") format("opentype");
  }

  :root {
    color-scheme: dark;
    --bg: #070b24;
    --panel: #121a4a;
    --panel-2: #1d2f77;
    --text: #ffffff;
    --muted: #c8d6ff;
    --line: #3658d8;
    --green: #37f58f;
    --blue: #28d7ff;
    --gold: #ffe34d;
    --violet: #9f5cff;
    --pink: #ff4fd8;
    --shadow: rgba(0, 0, 0, 0.38);
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background:
      radial-gradient(circle at 18% 12%, rgba(255, 227, 77, 0.24), transparent 16rem),
      radial-gradient(circle at 84% 8%, rgba(255, 79, 216, 0.22), transparent 18rem),
      linear-gradient(145deg, #070b24 0%, #162b88 46%, #5e2fd6 100%);
    color: var(--text);
    font-family: "Burbank Big Condensed", Impact, Haettenschweiler, "Arial Narrow Bold", Inter, ui-sans-serif, system-ui, sans-serif;
    letter-spacing: 0;
  }

  body::before {
    position: fixed;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(115deg, transparent 0 40%, rgba(255, 255, 255, 0.08) 40% 41%, transparent 41% 100%),
      repeating-linear-gradient(135deg, rgba(255, 255, 255, 0.045) 0 2px, transparent 2px 22px);
    content: "";
    pointer-events: none;
  }

  button,
  input {
    font: inherit;
  }

  .shell {
    width: min(1320px, calc(100% - 32px));
    margin: 0 auto;
    padding: 34px 0 44px;
  }

  .hero {
    display: grid;
    grid-template-columns: 1fr minmax(280px, 420px);
    gap: 24px;
    align-items: end;
    margin-bottom: 18px;
    border: 3px solid rgba(255, 255, 255, 0.18);
    border-radius: 8px;
    padding: 22px;
    background:
      linear-gradient(135deg, rgba(40, 215, 255, 0.18), rgba(159, 92, 255, 0.3)),
      rgba(7, 11, 36, 0.72);
    box-shadow: 0 18px 40px var(--shadow), inset 0 0 0 1px rgba(255, 255, 255, 0.14);
  }

  .eyebrow,
  .element {
    margin: 0 0 8px;
    color: var(--gold);
    font-family: Inter, ui-sans-serif, system-ui, sans-serif;
    font-size: 0.82rem;
    font-weight: 900;
    letter-spacing: 0;
    text-transform: uppercase;
    text-shadow: 0 2px 0 rgba(0, 0, 0, 0.45);
  }

  h1 {
    margin: 0;
    color: var(--text);
    font-size: clamp(3.8rem, 9vw, 8rem);
    line-height: 0.9;
    text-shadow:
      0 5px 0 #1230a5,
      0 9px 0 rgba(0, 0, 0, 0.45),
      0 0 28px rgba(40, 215, 255, 0.42);
    text-transform: uppercase;
  }

  .intro {
    max-width: 660px;
    margin: 18px 0 0;
    color: var(--muted);
    font-family: Inter, ui-sans-serif, system-ui, sans-serif;
    font-size: 1rem;
    font-weight: 800;
    line-height: 1.5;
  }

  .summary {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    overflow: hidden;
    border: 2px solid rgba(255, 255, 255, 0.2);
    border-radius: 8px;
    background: rgba(7, 11, 36, 0.76);
    box-shadow: inset 0 0 18px rgba(40, 215, 255, 0.12);
  }

  .summary div {
    min-width: 0;
    padding: 18px;
    border-left: 2px solid rgba(255, 255, 255, 0.16);
  }

  .summary div:first-child {
    border-left: 0;
  }

  .summary span {
    display: block;
    color: var(--gold);
    font-size: 2.35rem;
    font-weight: 900;
    text-shadow: 0 3px 0 #704c00;
  }

  .summary small {
    color: var(--text);
    font-family: Inter, ui-sans-serif, system-ui, sans-serif;
    font-weight: 900;
    text-transform: uppercase;
  }

  .share-button {
    grid-column: 1 / -1;
    min-height: 48px;
    border: 0;
    border-top: 2px solid rgba(255, 255, 255, 0.16);
    padding: 0 18px;
    background: linear-gradient(180deg, var(--green), #119f58);
    color: #031c11;
    cursor: pointer;
    font-size: 1rem;
    font-weight: 900;
    text-transform: uppercase;
    transition: filter 160ms ease, transform 120ms ease;
  }

  .share-button:hover,
  .share-button:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.84);
    outline-offset: -4px;
    filter: brightness(1.08);
  }

  .share-button:active {
    transform: translateY(1px);
  }

  .matrix-wrap {
    overflow-x: auto;
    border: 3px solid rgba(255, 255, 255, 0.2);
    border-radius: 8px;
    background: rgba(7, 11, 36, 0.82);
    box-shadow: 0 22px 44px var(--shadow);
  }

  .sprite-matrix {
    display: grid;
    grid-template-columns: minmax(210px, 260px) repeat(8, minmax(148px, 1fr));
    gap: 2px;
    min-width: 1390px;
    background: rgba(255, 255, 255, 0.18);
  }

  .matrix-header,
  .sprite-type,
  .sprite-cell {
    background: rgba(10, 18, 66, 0.98);
  }

  .matrix-header {
    position: sticky;
    top: 0;
    z-index: 2;
    min-height: 50px;
    padding: 15px 12px;
    background: linear-gradient(180deg, #ffe34d, #f39c12);
    color: #171000;
    font-family: Inter, ui-sans-serif, system-ui, sans-serif;
    font-size: 0.92rem;
    font-weight: 900;
    text-align: center;
    text-shadow: 0 1px 0 rgba(255, 255, 255, 0.38);
    text-transform: uppercase;
  }

  .sprite-type-heading,
  .sprite-type {
    position: sticky;
    left: 0;
    z-index: 3;
  }

  .sprite-type {
    min-height: 230px;
    padding: 16px;
    background: linear-gradient(160deg, rgba(30, 54, 150, 0.98), rgba(15, 25, 86, 0.98));
    box-shadow: inset -10px 0 24px rgba(0, 0, 0, 0.24);
  }

  h2 {
    margin: 0;
    color: var(--text);
    font-size: 1.35rem;
    line-height: 1;
    text-shadow: 0 3px 0 rgba(0, 0, 0, 0.5);
    text-transform: uppercase;
  }

  h2 a {
    color: inherit;
    text-decoration: none;
  }

  h2 a:hover,
  h2 a:focus-visible {
    color: var(--gold);
    outline: none;
    text-decoration: underline;
    text-decoration-thickness: 2px;
  }

  .sprite-type p:last-child {
    color: var(--muted);
    font-family: Inter, ui-sans-serif, system-ui, sans-serif;
    font-size: 0.86rem;
    font-weight: 700;
    line-height: 1.45;
  }

  .sprite-cell {
    display: grid;
    grid-template-rows: 104px minmax(26px, auto) auto;
    align-items: start;
    min-height: 230px;
    padding: 10px;
  }

  .sprite-cell[data-status="extracted"] {
    background: linear-gradient(180deg, rgba(55, 245, 143, 0.22), rgba(10, 18, 66, 0.98));
  }

  .sprite-cell[data-status="mastered"] {
    background: linear-gradient(180deg, rgba(255, 227, 77, 0.34), rgba(10, 18, 66, 0.98));
  }

  .sprite-cell[data-released="false"] {
    background: rgba(10, 14, 40, 0.92);
  }

  .sprite-cell[data-released="false"] .cell-art img {
    opacity: 0.5;
    filter:
      brightness(0)
      saturate(0)
      invert(0.12)
      drop-shadow(0 0 6px rgba(40, 215, 255, 0.1))
      drop-shadow(0 4px 0 rgba(0, 0, 0, 0.32))
      drop-shadow(0 14px 14px rgba(0, 0, 0, 0.44));
  }

  .sprite-cell[data-released="false"] .status-badge {
    opacity: 0.62;
  }

  .sprite-cell.empty {
    display: grid;
    place-items: center;
    color: rgba(174, 184, 199, 0.38);
    font-size: 1.4rem;
    font-weight: 900;
  }

  .cell-art {
    display: grid;
    place-items: center;
    min-height: 104px;
  }

  .cell-art img {
    display: block;
    max-width: 94px;
    max-height: 94px;
    object-fit: contain;
    filter:
      drop-shadow(0 0 6px rgba(40, 215, 255, 0.1))
      drop-shadow(0 4px 0 rgba(0, 0, 0, 0.32))
      drop-shadow(0 16px 16px rgba(0, 0, 0, 0.44));
