const title = 'fortsprite - Fortnite Sprite Checker';
const description = 'Track every current and unreleased Fortnite Sprite variant you have extracted, mastered, or still need to find. Your checklist saves privately in your browser.';
const canonical = 'https://fortsprite.com/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#121826" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="fortsprite" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebApplication',
      name: 'fortsprite',
      url: canonical,
      applicationCategory: 'GameApplication',
      operatingSystem: 'Any',
      description
    })} />
  </head>
  <body>
    <main class="shell">
      <section class="hero" aria-labelledby="page-title">
        <div>
          <p class="eyebrow">Fortnite Sprite Checklist</p>
          <h1 id="page-title">fortsprite</h1>
          <p class="intro">
            Mark each sprite as not found, extracted, or mastered. Progress is saved on this device.
          </p>
        </div>
        <div class="summary" aria-label="Sprite progress">
          <div>
            <span id="mastered-count">0</span>
            <small>Mastered</small>
          </div>
          <div>
            <span id="extracted-count">0</span>
            <small>Extracted</small>
          </div>
          <div>
            <span id="missing-count">{sprites.length}</span>
            <small>Not found</small>
          </div>
        </div>
      </section>

      <section class="matrix-wrap" aria-label="Sprite checklist">
        <div class="sprite-matrix">
          <div class="matrix-header sprite-type-heading">Sprite</div>
          {variants.map((variant) => (
            <div class="matrix-header" data-variant-column={variant}>{variant === 'Base' ? 'Regular' : variant}</div>
          ))}

          {spriteRows.map((row) => (
            <>
              <article class="sprite-type" data-sprite-row>
                <p class="element">{row.rarity}</p>
                <h2>{row.name}</h2>
                <p>{row.ability}</p>
              </article>
              {row.cells.map((sprite, index) => (
                sprite ? (
                  <div
                    class="sprite-cell"
                    data-sprite-card
                    data-id={sprite.id}
                    data-variant={sprite.variant}
                    data-released={String(sprite.released)}
                    data-exact-image={String(sprite.hasExactImage)}
                    data-status="not-found"
                    role={sprite.released ? 'button' : 'group'}
                    tabindex={sprite.released ? '0' : undefined}
                    aria-label={`${sprite.name} status: None`}
                  >
                    <div class="cell-art">
                      <img src={sprite.image} alt={sprite.name} loading="lazy" decoding="async" />
                    </div>
                    <div class="cell-meta">
                    </div>
                    <span class="status-badge" data-status-badge>
                      {sprite.released ? 'None' : 'Locked'}
                    </span>
                  </div>
                ) : (
                  <div class="sprite-cell empty" data-empty-cell data-variant={variants[index]} aria-label={`No ${variants[index]} variant for ${row.name}`}>-</div>
                )
              ))}
            </>
          ))}
        </div>
      </section>
    </main>

    <script>
      const storageKey = 'fortsprite:v1';
      const cards = Array.from(document.querySelectorAll('[data-sprite-card]'));
      const counts = {
        mastered: document.querySelector('#mastered-count'),
        extracted: document.querySelector('#extracted-count'),
        missing: document.querySelector('#missing-count')
      };

      let state = {};

      try {
        state = JSON.parse(localStorage.getItem(storageKey) || '{}') || {};
      } catch {
        state = {};
      }

      function persist() {
        localStorage.setItem(storageKey, JSON.stringify(state));
      }

      function applyState() {
        const totals = { mastered: 0, extracted: 0, 'not-found': 0 };

        cards.forEach((card) => {
          const id = card.dataset.id;
          const isReleased = card.dataset.released === 'true';
          const status = state[id] || 'not-found';
          if (isReleased) totals[status] += 1;
          card.dataset.status = status;
          const label = !isReleased ? 'Locked' : status === 'not-found' ? 'None' : status === 'extracted' ? 'Extracted' : 'Mastered';
          const badge = card.querySelector('[data-status-badge]');
          if (badge) {
            badge.textContent = label;
          }
          card.setAttribute('aria-label', `${card.getAttribute('aria-label').replace(/ status:.*/, ' status')}: ${label}`);
        });

        counts.mastered.textContent = String(totals.mastered);
        counts.extracted.textContent = String(totals.extracted);
        counts.missing.textContent = String(totals['not-found']);
      }

      cards.forEach((card) => {
        function cycleStatus() {
          const current = state[card.dataset.id] || 'not-found';
          state[card.dataset.id] =
            current === 'not-found' ? 'extracted' : current === 'extracted' ? 'mastered' : 'not-found';
          persist();
          applyState();
        }

        card.addEventListener('click', () => {
          if (card.dataset.released !== 'true') return;
          cycleStatus();
        });

        card.addEventListener('keydown', (event) => {
          if (card.dataset.released !== 'true') return;
          if (event.key !== 'Enter' && event.key !== ' ') return;
          event.preventDefault();
          cycleStatus();
        });
      });

      applyState();
    </script>
  </body>
</html>

