---
import { SignUp } from "@clerk/astro/components";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign up | fortsprite</title>
    <meta name="robots" content="noindex" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body>
    <main class="auth-shell">
      <a class="brand-link" href="/">fortsprite</a>
      <section class="auth-panel" aria-label="Sign up">
        <SignUp />
      </section>
    </main>
  </body>
</html>

<style>
  body {
    margin: 0;
    min-height: 100vh;
    background:
      radial-gradient(circle at 18% 12%, rgba(255, 227, 77, 0.24), transparent 16rem),
      radial-gradient(circle at 84% 8%, rgba(255, 79, 216, 0.22), transparent 18rem),
      linear-gradient(145deg, #070b24 0%, #162b88 46%, #5e2fd6 100%);
    color: #ffffff;
    font-family: Inter, ui-sans-serif, system-ui, sans-serif;
  }

  .auth-shell {
    display: grid;
    gap: 22px;
    place-items: center;
    width: min(100% - 32px, 520px);
    min-height: 100vh;
    margin: 0 auto;
    padding: 32px 0;
  }

  .brand-link {
    color: #ffe34d;
    font-size: 1.55rem;
    font-weight: 900;
    text-decoration: none;
    text-transform: uppercase;
  }

  .brand-link:hover,
  .brand-link:focus-visible {
    text-decoration: underline;
  }

  .auth-panel {
    display: grid;
    place-items: center;
    width: 100%;
  }
</style>

<style is:global>
  [class^="cl-"],
  [class*=" cl-"] {
    font-family: Inter, ui-sans-serif, system-ui, sans-serif;
    letter-spacing: 0;
  }
</style>
